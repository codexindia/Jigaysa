# Copy this file to .env and fill in the values. Never commit .env.

# Core
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — MySQL by default. To switch to PostgreSQL, change DB_ENGINE to
# django.db.backends.postgresql and DB_PORT to 5432 (psycopg is in requirements).
# The app is DB-agnostic; no code changes are needed to switch.
DB_ENGINE=django.db.backends.mysql
DB_NAME=jigayasa
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# CORS (comma-separated origins for the web/mobile frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT lifetimes (minutes / days)
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Auth providers (pluggable; mock by default in dev)
SMS_PROVIDER=accounts.providers.ConsoleSMSProvider

# Object storage (S3 / S3-compatible) for media, thumbnails & videos.
# Leave AWS_STORAGE_BUCKET_NAME empty to disable the /api/v1/uploads/ endpoints.
# For Cloudflare R2 / MinIO / DigitalOcean Spaces, set AWS_S3_ENDPOINT_URL.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_ADDRESSING_STYLE=virtual
AWS_S3_UPLOAD_EXPIRY=900
AWS_S3_DOWNLOAD_EXPIRY=3600
AWS_S3_MAX_UPLOAD_BYTES=1073741824
